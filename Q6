// Write a program to Reverse a number.
#include<stdio.h>
int main(){
    int n, reverse=0, d, temp;
    printf("Enter the number which you want to reverse: \n");
    scanf("%d", &n);
    temp=n;
    while(n!=0)
    {
        d=n%10;
        reverse= reverse*10+d;
        n/=10;
    }
    printf("Reverse of %d is: %d", temp, reverse);
    return 0;
}
