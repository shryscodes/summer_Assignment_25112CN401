//this program reverses a number given input by user
#include<stdio.h>
int main(){
    int n, temp, reverse=0, d;
    printf("Enter a number: \n");
    scanf("%d", &n);
    temp=n;
    while(n!=0)
    {
        d=n%10;
        reverse = reverse*10+ d;
        n/=10;
    }
    printf("Reverse of %d is: %d", temp, reverse);
    return 0;
}
