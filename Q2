//Write a program to Print multiplication table of
//a given number
#include<stdio.h>
int main(){
    int n;
    printf("Enter the number whose table you want to print: \n");
    scanf("%d", &n);
    for (int i = 0; i <=10; i++)
    {
        printf("%dX%d=%d\n",n, i, n*i);
    }
    
    return 0;
}
