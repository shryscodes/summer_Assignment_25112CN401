// Write a program to Check whether a number is
// palindrome.
#include<stdio.h>
int main(){
    int n, reverse=0, d, temp;
    printf("Enter the number which you want to check is pallidrome or not: \n");
    scanf("%d", &n);
    temp=n;
    while(n!=0)
    {
        d=n%10;
        reverse= reverse*10+d;
        n/=10;
    }
    if(reverse==temp)
    printf("%d is a pallindrome number\n", temp);
    else
    printf("%d is not a pallindrome number\n", temp);
    return 0;
}
