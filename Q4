// Write a program to Count digits in a number.
#include<stdio.h>
int main(){
    int n, count=0, temp;
    printf("Enter the number whose digits you want to count: \n");
    scanf("%d", &n);
    temp=n;
    while (n!=0)
    {
        n/=10;
        count++;
    }
    printf("Digits in %d: %d", temp, count);
    return 0;
}
