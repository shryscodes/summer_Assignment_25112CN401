// Write a program to Find sum of digits of a
// number.
#include<stdio.h>
int main(){
    int n, d, temp, sum=0;
    printf("Enter the number whose digits you want to sum: \n");
    scanf("%d", &n);
    temp=n;
    while (n!=0)
    {
        d=n%10;
        sum+=d;
        n/=10;
    }
    printf("Sum of digtis of %d: %d", temp, sum);
    return 0;
}
